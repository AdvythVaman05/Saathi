# ==============================================================================
# Saathi - Production Environment Variables Template
# ==============================================================================
# Copy this file to '.env' or add these to your cloud provider dashboard.
# DO NOT commit real credentials to your repository.

# Django Core Config
DJANGO_SECRET_KEY=generate-a-secure-random-64-character-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=saathi-backend.up.railway.app,127.0.0.1,localhost

# Database Connectivity (Supabase Transaction Pooler recommended)
DATABASE_URL=postgresql://postgres:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# Redis Cache and Websocket Channel Broker
REDIS_URL=rediss://default:[PASSWORD]@redis-instance-name.up.railway.app:6379/0

# CORS and CSRF Whitelists
DJANGO_CORS_ALLOWED_ORIGINS=https://saathi.vercel.app,http://localhost:3000
DJANGO_CORS_ALLOWED_ORIGIN_REGEXES=^https:\/\/saathi-.*\.vercel\.app$
DJANGO_CSRF_TRUSTED_ORIGINS=https://saathi.vercel.app,http://localhost:3000

# Voice Engine Credentials (Isolated Server-Side)
GROQ_API_KEY=gsk_proj_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GROQ_WHISPER_MODEL=whisper-large-v3

# Deprecated Voice Providers (No longer active in end-to-end flow)
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AZURE_SPEECH_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AZURE_SPEECH_REGION=eastus

# Supabase Client Credentials (Optional client-side access)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
