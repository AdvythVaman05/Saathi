# Supabase PostgreSQL Configuration
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres

# Django settings
DJANGO_SECRET_KEY=django-insecure-saathi-production-key-change-this-in-env
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Redis settings (Broker for Celery & Django Channels channel layer)
REDIS_URL=redis://localhost:6379/0

# Speech APIs Configuration
GROQ_API_KEY=your-groq-api-key
GROQ_WHISPER_MODEL=whisper-large-v3

# Deprecated Providers (No longer active in end-to-end flow)
OPENAI_API_KEY=your-openai-api-key
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastus

# Next.js Settings
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/speech
